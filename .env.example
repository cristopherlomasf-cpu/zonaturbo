# ZONA TURBO - Variables de entorno
# Copia este archivo como .env y completa los valores reales
# NUNCA subas .env a GitHub

# ── Base de Datos ─────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=zonaturbo
DB_USER=root
DB_PASS=

# ── JWT ───────────────────────────────────────────────────────
# Genera una clave aleatoria segura (mínimo 32 caracteres)
# En Linux: openssl rand -hex 32
JWT_SECRET=CAMBIAR_POR_CLAVE_SEGURA_DE_AL_MENOS_32_CARACTERES

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
APP_URL=http://localhost
FRONTEND_URL=http://localhost
APP_DEBUG=true
